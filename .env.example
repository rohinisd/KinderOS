# ============================================================
# KinderOS — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ─────────────────────────────────────────
# DATABASE (Supabase — create a NEW project for KinderOS)
# Get from: supabase.com → Your project → Settings → Database
# Region: ap-south-1 (Mumbai) for Indian data residency
# ─────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────
# CLERK (Authentication & Multi-tenancy)
# Get from: clerk.com → Your app → API Keys
# Enable Organizations in Clerk Dashboard
# ─────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"
# OPTIONAL: Only needed on Clerk paid plan. Free tier uses auto-provision instead.
# CLERK_WEBHOOK_SECRET="whsec_..."

# ─────────────────────────────────────────
# RAZORPAY (Payments — Indian gateway)
# Get from: razorpay.com → Settings → API Keys
# Use TEST keys for development, LIVE for production
# ─────────────────────────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."
RAZORPAY_WEBHOOK_SECRET="..."

# ─────────────────────────────────────────
# TWILIO (WhatsApp + SMS)
# Get from: console.twilio.com
# App runs in dev mode (console logs) if not configured
# ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"
TWILIO_SMS_NUMBER=""

# ─────────────────────────────────────────
# CLOUDFLARE R2 (File Storage)
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
# ─────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID="..."
R2_ACCESS_KEY_ID="..."
R2_SECRET_ACCESS_KEY="..."
R2_BUCKET_NAME="kinderos-files"
R2_PUBLIC_URL="https://files.kinderos.in"

# ─────────────────────────────────────────
# ANTHROPIC (AI — Progress Report Generation)
# NEVER expose this to the client side
# ─────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─────────────────────────────────────────
# RESEND (Transactional Email)
# ─────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="KinderOS <noreply@kinderos.in>"

# ─────────────────────────────────────────
# FIREBASE (Push Notifications)
# ─────────────────────────────────────────
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# ─────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="KinderOS"
NEXT_PUBLIC_SUPPORT_EMAIL="support@kinderos.in"
# Comma-separated hostnames that show the SaaS marketing home at / (not a school custom domain).
# Add your production apex domain when you use a custom domain for KinderOS itself.
PLATFORM_HOSTS="localhost,127.0.0.1,kinderos.vercel.app"
SUPER_ADMIN_EMAILS=""
CRON_SECRET=""
# Backup center (superadmin UI for GitHub Actions artifacts)
GITHUB_BACKUP_REPO=""
GITHUB_BACKUP_TOKEN=""

# ─────────────────────────────────────────
# NOTES
# ─────────────────────────────────────────
# Timezone: Asia/Kolkata (IST = UTC+5:30)
# Currency: INR stored as PAISE integers (1 INR = 100 paise)
# Date display: DD/MM/YYYY
# Academic year: April-March, labelled "2025-26"
# Default state: Karnataka (code: 29)
# GST: CGST+SGST intrastate, IGST interstate
# Standalone output: npm run build produces self-hosted server.js
