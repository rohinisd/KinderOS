{
  "name": "kinderos",
  "version": "0.1.0",
  "private": true,
  "description": "KinderOS — Multi-tenant SaaS for Kindergarten Schools (India)",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo typecheck",
    "postinstall": "pnpm run db:generate",
    "db:push": "pnpm --filter @kinderos/db run db:push",
    "db:studio": "pnpm --filter @kinderos/db run db:studio",
    "db:seed": "pnpm --filter @kinderos/db run db:seed",
    "db:generate": "pnpm --filter @kinderos/db run db:generate",
    "db:migrate": "pnpm --filter @kinderos/db run db:migrate"
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
